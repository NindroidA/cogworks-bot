# ──────────────────────────────────────────────
# Environment & Mode
# ──────────────────────────────────────────────

# Set to 'prod' or 'dev'
RELEASE=

# Bot owner ID — required for /status commands (restricts to bot owner only)
BOT_OWNER_ID=

# ──────────────────────────────────────────────
# Bot Credentials
# ──────────────────────────────────────────────

# Production bot
BOT_TOKEN=
CLIENT_ID=

# Development bot (only needed if RELEASE=dev)
#DEV_BOT_TOKEN=
#DEV_CLIENT_ID=

# Development guild — skips API webhooks and join tracking for this server
#DEV_GUILD_ID=

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────

MYSQL_DB_HOST=
MYSQL_DB_PORT=
MYSQL_DB_USERNAME=
MYSQL_DB_PASSWORD=
MYSQL_DB_DATABASE=

# ──────────────────────────────────────────────
# Storage
# ──────────────────────────────────────────────

TEMP_STORAGE_PATH=temp/

# ──────────────────────────────────────────────
# API & Dashboard Integration
# (URLs default to production endpoints)
# ──────────────────────────────────────────────

# Internal API for dashboard → bot communication
COGWORKS_INTERNAL_API_TOKEN=
# Optional: Internal API port (default: 3002)
#BOT_INTERNAL_PORT=3002

# Dashboard URL
# Production: https://cogworks.nindroidsystems.com/dashboard
# Development: http://localhost:3000/dashboard
DASHBOARD_URL=

# NinSys API base URL
# Production: https://api.nindroidsystems.com
# Development: http://localhost:3001
API_URL=

# ──────────────────────────────────────────────
# Channels & Notifications (optional)
# ──────────────────────────────────────────────

# Public channel for status update embeds
#STATUS_CHANNEL_ID=

# Private channel for memory/heap alerts (falls back to STATUS_CHANNEL_ID)
#MEMORY_ALERT_CHANNEL_ID=

# ──────────────────────────────────────────────
# Maintenance Mode
# ──────────────────────────────────────────────

# Set to 'true' to run in maintenance mode (no DB required, minimal footprint)
# Bot stays online on Discord and replies to all interactions with a maintenance message
#MAINTENANCE_MODE=true

# ──────────────────────────────────────────────
# Health & Monitoring
# ──────────────────────────────────────────────

#HEALTH_PORT=3003
#MEMORY_THRESHOLD_MB=512

# ──────────────────────────────────────────────
# Error Reporting (optional)
# ──────────────────────────────────────────────

# Discord webhook URL that receives MEDIUM+ error alerts.
# Leave empty to disable external reporting entirely — errors still go to
# stdout/file logs regardless. Identical errors are deduplicated for 60s and
# rate-limited to 10/minute.
#ERROR_WEBHOOK_URL=https://discord.com/api/webhooks/<id>/<token>

# Master toggle. If unset, defaults to enabled in prod and disabled in dev.
# Set to 'false' to silence reporting even when ERROR_WEBHOOK_URL is present.
#ERROR_REPORTING_ENABLED=true

# ──────────────────────────────────────────────
# Bait Channel — Appeal Tokens (v3.2.0+)
# ──────────────────────────────────────────────

# 32-byte (or longer) random secret used to sign single-use appeal tokens
# embedded in pre-ban DMs. Bot will refuse to start with a missing/empty
# value when any guild has bait `enableAppealLink=true`. Generate via:
#   node -e 'console.log(require("crypto").randomBytes(32).toString("base64url"))'
# Rotate by setting the new secret here — old tokens will fail HMAC verify
# (intentional; treat appeals as time-limited).
APPEAL_HMAC_SECRET=
