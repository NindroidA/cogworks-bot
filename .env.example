# Set to 'prod' or 'dev'
RELEASE=

# Production bot credentials
BOT_TOKEN=
CLIENT_ID=

# Optional: Development bot credentials (only needed if RELEASE=dev)
#DEV_BOT_TOKEN=
#DEV_CLIENT_ID=

# Bot owner ID — required for /status commands (restricts to bot owner only, 
# so if anyone else is reading this, yes this is only for me and no it won't work for you lol)
BOT_OWNER_ID=

# Optional: Channel ID for posting status update embeds
#STATUS_CHANNEL_ID=

# MySQL database credentials
MYSQL_DB_HOST=
MYSQL_DB_PORT=
MYSQL_DB_USERNAME=
MYSQL_DB_PASSWORD=
MYSQL_DB_DATABASE=

# Temporary storage path for transcripts (default: temp/)
TEMP_STORAGE_PATH=temp/

# API integration (for NinSys API)
# Production: https://api.nindroidsystems.com
# Development: http://localhost:3001
API_URL=

# Optional: Health check HTTP port (default: 3000)
#HEALTH_PORT=3000

# Optional: RSS memory threshold in MB for degraded health status (default: 512)
#MEMORY_THRESHOLD_MB=512

# Internal API (for dashboard → bot communication)
# Generate a strong random token: openssl rand -hex 32
COGWORKS_INTERNAL_API_TOKEN=
# Optional: Internal API port (default: 3002)
#BOT_INTERNAL_PORT=3002

# Dashboard URL (default: https://cogworks.nindroidsystems.com)
# Set to http://localhost:3000 for local development
#DASHBOARD_URL=https://cogworks.nindroidsystems.com